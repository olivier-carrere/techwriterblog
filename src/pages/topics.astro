---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const key = tag.toLowerCase();
    tagMap.set(key, (tagMap.get(key) ?? 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<Layout
  title="Topics — Technical Writing Blog"
  description="Browse all topics covered on the blog: docs-as-code, DITA XML, YAML, AI documentation, Markdown, and more."
>
  <Container>
    <div class="mx-auto max-w-3xl mt-14 mb-20">
      <p class="text-blue-400 uppercase tracking-wider text-sm font-medium mb-2">Browse</p>
      <h1 class="text-4xl font-bold mb-2">Topics</h1>
      <p class="text-gray-500 dark:text-slate-400 mb-10">{tags.length} topics across {posts.length} articles</p>

      <ul class="flex flex-wrap gap-3">
        {tags.map(([tag, count]) => {
          const display = tag.charAt(0).toUpperCase() + tag.slice(1);
          return (
            <li>
              <a
                href={`/tag/${tag}`}
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-gray-200 dark:border-slate-700 text-sm text-gray-700 dark:text-slate-100 hover:border-blue-400 hover:text-blue-700 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-slate-800 transition"
              >
                {display}
                <span class="text-xs text-gray-400 dark:text-slate-500">{count}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </Container>
</Layout>
