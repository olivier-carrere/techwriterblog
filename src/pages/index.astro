---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

function readingTime(body: string): number {
  const text = body
    .replace(/^import\s.+$/gm, "")
    .replace(/```[\s\S]*?```/g, "")
    .replace(/<[^>]+>/g, " ")
    .replace(/[#*`_~[\]()!>|]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  const words = text.split(" ").filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const publishedBlogEntries = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

publishedBlogEntries.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = publishedBlogEntries.slice(0, 3);
const rest = publishedBlogEntries.slice(3);
---

<Layout
  title="Technical Writing Blog — Docs-as-Code, AI Documentation & YAML"
  description="Expert articles on technical writing, docs-as-code, DITA XML, Markdown, YAML, and AI-assisted documentation workflows by Olivier Carrère."
>
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://redaction-technique.org/#website",
      "url": "https://redaction-technique.org",
      "name": "Redaction-technique.org",
      "author": { "@id": "https://redaction-technique.org/#olivier-carrere" }
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "https://redaction-technique.org/#olivier-carrere",
      "name": "Olivier Carrère",
      "url": "https://redaction-technique.org",
      "jobTitle": "Technical Writer",
      "sameAs": ["https://www.linkedin.com/in/carrereolivier/"]
    }
  ])} />

  <Container>
    <!-- Hero -->
    <div class="mt-16 mb-14 max-w-2xl">
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        Markup and Meaning
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
        Articles on docs-as-code, structured authoring, and AI-assisted documentation by Olivier Carrère — a technical writer specialising in DITA XML, Markdown, and YAML.
        Practical writing on how structure, automation, and the right tools make documentation scale.
      </p>
    </div>

    <!-- Featured: 3 most recent as cards -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-5">Latest</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {featured.map((post, index) => (
          <a href={`/blog/${post.slug}`} class="group flex flex-col rounded-xl border border-gray-100 dark:border-slate-700 overflow-hidden hover:border-blue-200 dark:hover:border-blue-700 hover:shadow-md transition">
            <img
              src={post.data.image.src}
              alt={post.data.image.alt}
              class="w-full h-44 object-cover"
              loading={index === 0 ? "eager" : "lazy"}
              decoding={index === 0 ? "sync" : "async"}
            />
            <div class="flex flex-col flex-1 p-4 bg-white dark:bg-slate-800">
              <span class="text-xs font-medium text-blue-500 uppercase tracking-wider mb-1">{post.data.category}</span>
              <h3 class="font-semibold text-gray-900 dark:text-slate-100 leading-snug group-hover:text-blue-700 dark:group-hover:text-blue-400 transition mb-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-500 dark:text-slate-400 line-clamp-2 flex-1">{post.data.snippet}</p>
              <div class="flex items-center gap-2 mt-3">
                <time class="text-xs text-gray-500 dark:text-slate-500" datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                </time>
                <span class="text-gray-300 dark:text-slate-600">·</span>
                <span class="text-xs text-gray-500 dark:text-slate-500">{readingTime(post.body)} min read</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Compact list for remaining posts -->
    {rest.length > 0 && (
      <section class="mt-14 mb-16">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">More articles</h2>
        <ul class="divide-y divide-gray-100 dark:divide-slate-800">
          {rest.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="group flex items-baseline justify-between gap-4 py-3 hover:text-blue-700 dark:hover:text-blue-400 transition">
                <span class="font-medium text-gray-800 dark:text-slate-200 group-hover:text-blue-700 dark:group-hover:text-blue-400 leading-snug">{post.data.title}</span>
                <span class="text-xs text-gray-500 dark:text-slate-500 shrink-0 flex gap-2">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                  </time>
                  <span>· {readingTime(post.body)} min</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </Container>
</Layout>
