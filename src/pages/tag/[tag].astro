---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tagMap = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      const key = tag.toLowerCase();
      if (!tagMap.has(key)) tagMap.set(key, []);
      tagMap.get(key)!.push(post);
    }
  }
  return [...tagMap.entries()].map(([tag, articles]) => ({
    params: { tag },
    props: {
      tag,
      articles: articles.sort(
        (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
      ),
    },
  }));
}

const { tag, articles } = Astro.props;
const displayTag = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<Layout
  title={`${displayTag} articles — Technical Writing Blog`}
  description={`All articles tagged with ${displayTag} on docs-as-code, technical writing, and AI documentation.`}
>
  <Container>
    <div class="mx-auto max-w-3xl mt-14">
      <p class="text-blue-400 uppercase tracking-wider text-sm font-medium mb-2">Tag</p>
      <h1 class="text-4xl font-bold mb-2">{displayTag}</h1>
      <p class="text-gray-500 mb-10">{articles.length} article{articles.length !== 1 ? "s" : ""}</p>

      <ul class="grid gap-8">
        {articles.map((post) => (
          <li>
            <a
              href={`/blog/${post.slug}`}
              class="group flex gap-5 items-start hover:bg-gray-50 rounded-xl p-3 -mx-3 transition"
            >
              {post.data.image?.src && (
                <img
                  src={post.data.image.src}
                  alt={post.data.image.alt ?? post.data.title}
                  class="w-24 h-24 object-cover rounded-lg flex-shrink-0"
                  loading="lazy"
                />
              )}
              <div>
                <h2 class="font-semibold text-lg leading-snug group-hover:text-blue-700 transition">
                  {post.data.title}
                </h2>
                <p class="text-sm text-gray-500 mt-1">{post.data.snippet}</p>
                <time class="text-xs text-gray-500 mt-2 block" datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                </time>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <div class="text-center mt-12">
        <a href="/" class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition">
          ← Back to Blog
        </a>
      </div>
    </div>
  </Container>
</Layout>
