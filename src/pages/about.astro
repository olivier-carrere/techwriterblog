---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const siteUrl = "https://redaction-technique.org";

const jsonLdArray = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${siteUrl}/#olivier-carrere`,
    name: "Olivier Carrère",
    url: siteUrl,
    jobTitle: "Technical Writer",
    description:
      "Technical writer at Unity, specialising in docs-as-code, DITA XML, structured authoring, and AI-assisted documentation workflows.",
    knowsAbout: [
      "DITA XML", "Markdown", "docs-as-code", "technical writing",
      "YAML", "AI documentation", "structured authoring", "information architecture",
    ],
    sameAs: ["https://www.linkedin.com/in/carrereolivier/"],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "About", item: `${siteUrl}/about` },
    ],
  },
];

const expertise = [
  {
    title: "Docs-as-code",
    desc: "Git-based workflows, CI/CD pipelines for documentation, Markdown and lightweight markup at scale.",
  },
  {
    title: "Structured authoring",
    desc: "DITA XML topic-based writing, content reuse strategies, single-sourcing, and information typing.",
  },
  {
    title: "AI-assisted workflows",
    desc: "Integrating LLMs into documentation pipelines — translation, first-draft generation, and quality checks.",
  },
  {
    title: "Information architecture",
    desc: "Taxonomy design, content modelling, and navigation systems for large documentation sets.",
  },
  {
    title: "YAML & data-driven docs",
    desc: "Generating structured content from YAML data sources; separating content from presentation.",
  },
  {
    title: "Developer documentation",
    desc: "API references, SDK guides, onboarding docs, and code-adjacent content for technical audiences.",
  },
];

const tools = [
  "DITA XML / Oxygen XML",
  "Markdown / MDX",
  "Git & GitHub",
  "Astro / Static site generators",
  "YAML",
  "Mermaid diagrams",
  "VS Code",
  "LLM-assisted editing",
];
---

<Layout
  title="About Olivier Carrère — Technical Writer"
  description="Olivier Carrère is a technical writer at Unity, specialising in docs-as-code, DITA XML, structured authoring, and AI-assisted documentation."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdArray)} />
  </Fragment>

  <Container>
    <div class="mx-auto max-w-3xl mt-14 mb-20">

      <!-- Hero: name + title -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-8 mb-12">
        <div>
          <p class="text-blue-600 uppercase tracking-wider text-sm font-medium mb-1">About</p>
          <h1 class="text-3xl lg:text-4xl font-bold tracking-tight leading-tight mb-2">
            Olivier Carrère
          </h1>
          <p class="text-base text-slate-500 dark:text-slate-400 mb-4">
            Technical Writer · Unity · Paris
          </p>
          <div class="flex gap-3">
            <a
              href="https://www.linkedin.com/in/carrereolivier/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-gray-200 dark:border-slate-700 text-sm text-gray-600 dark:text-slate-300 hover:border-blue-400 hover:text-blue-700 dark:hover:text-blue-400 transition"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-3.5 h-3.5 fill-current shrink-0" aria-hidden="true">
                <path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.88 0 54.11S24.09 0 53.79 0s53.79 24.22 53.79 54.11-24.1 54-53.79 54zM447.9 448h-92.68V302.4c0-34.7-12.42-58.3-43.5-58.3-23.73 0-37.84 16-44.04 31.4-2.28 5.6-2.85 13.4-2.85 21.2V448h-92.68s1.24-241.8 0-266.1h92.68v37.7c12.3-19 34.3-46.2 83.3-46.2 60.8 0 106.5 39.7 106.5 125.1V448z"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>
      </div>

      <!-- Bio -->
      <div class="space-y-4 text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-16">
        <p>
          Technical writer at <strong class="text-gray-900 dark:text-slate-100">Unity</strong>, specialising in
          <strong class="text-gray-900 dark:text-slate-100">docs-as-code</strong>,
          <strong class="text-gray-900 dark:text-slate-100">DITA XML</strong>, and
          <strong class="text-gray-900 dark:text-slate-100">AI-assisted documentation workflows</strong>.
        </p>
        <p>
          I work on documentation systems that scale — from structured authoring pipelines to
          multi-product content architectures. My focus is on structure, automation, and the
          right tooling choices for long-lived technical content.
        </p>
        <p>
          This blog is where I publish practical articles on the tools and methods I use daily:
          markup languages, content modelling, AI in the documentation workflow, and the craft of
          writing clearly for technical audiences.
        </p>
      </div>

      <!-- Expertise grid -->
      <h2 class="text-2xl font-bold mb-6">Domains of expertise</h2>
      <div class="grid sm:grid-cols-2 gap-5 mb-16">
        {expertise.map((item) => (
          <div class="rounded-xl border border-gray-100 dark:border-slate-700 p-5 bg-gray-50 dark:bg-slate-800">
            <h3 class="font-semibold text-gray-900 dark:text-slate-100 mb-1">{item.title}</h3>
            <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Tools -->
      <h2 class="text-2xl font-bold mb-5">Tools & technologies</h2>
      <ul class="flex flex-wrap gap-2 mb-16" aria-label="Tools and technologies">
        {tools.map((tool) => (
          <li class="px-3 py-1.5 rounded-full bg-blue-50 dark:bg-slate-700 text-blue-700 dark:text-blue-300 text-sm font-medium">
            {tool}
          </li>
        ))}
      </ul>

      <!-- Contact form -->
      <div class="border-t border-gray-100 dark:border-slate-800 pt-14">
        <h2 class="text-2xl font-bold mb-2">Get in touch</h2>
        <p class="text-gray-500 dark:text-slate-400 mb-8 leading-relaxed">
          Whether you want to discuss something you read here, exchange ideas on docs-as-code or DITA,
          or simply connect professionally — use the form below.
        </p>

        <!--
          Contact form powered by Web3Forms (free tier, no backend needed).
          Get your access key at https://web3forms.com/ and replace YOUR_ACCESS_KEY_HERE below.
        -->
        <form id="contact-form" class="space-y-5" novalidate>
          <input type="hidden" name="access_key" value="726cf15d-321e-47cc-afe8-f9dfcc9c273e" />
          <input type="hidden" name="subject" value="Message from redaction-technique.org/about" />
          <input type="hidden" name="from_name" value="redaction-technique.org" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" aria-hidden="true" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="cf-name" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1.5">
                Name <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                id="cf-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                placeholder="Your name"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
              />
            </div>
            <div>
              <label for="cf-email" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1.5">
                Email <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                id="cf-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="your@email.com"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
              />
            </div>
          </div>

          <div>
            <label for="cf-message" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1.5">
              Message <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <textarea
              id="cf-message"
              name="message"
              required
              rows="5"
              placeholder="Your message…"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none text-sm"
            ></textarea>
          </div>

          <div class="flex items-center gap-4 flex-wrap">
            <button
              type="submit"
              id="cf-submit"
              class="px-6 py-2.5 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-slate-900 transition disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Send message
            </button>
            <p id="cf-status" class="text-sm" aria-live="polite" role="status"></p>
          </div>
        </form>
      </div>

    </div>
  </Container>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const btn  = document.getElementById("cf-submit") as HTMLButtonElement | null;
  const status = document.getElementById("cf-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (btn) btn.disabled = true;
    if (status) { status.textContent = "Sending…"; status.className = "text-sm text-gray-500"; }

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const data = await res.json();
      if (res.ok) {
        if (status) {
          status.textContent = "Message sent — thank you!";
          status.className = "text-sm text-green-600 dark:text-green-400";
        }
        form.reset();
      } else {
        throw new Error(data.message ?? "Submission failed");
      }
    } catch {
      if (status) {
        status.textContent = "Something went wrong. Please try again.";
        status.className = "text-sm text-red-600 dark:text-red-400";
      }
    } finally {
      if (btn) btn.disabled = false;
    }
  });
</script>
