---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

export const prerender = true;

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

function readingTime(body: string): number {
  const text = body
    .replace(/^import\s.+$/gm, "")
    .replace(/```[\s\S]*?```/g, "")
    .replace(/<[^>]+>/g, " ")
    .replace(/[#*`_~[\]()!>|]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  const words = text.split(" ").filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const { slug } = Astro.params;
const entries = await getCollection("blog");
const entry = entries.find((e) => e.slug === slug);

if (!entry) {
  throw new Error(`Blog entry not found for slug: ${slug}`);
}

// Related posts: rank by shared tags, exclude current, take top 3
const relatedPosts = entries
  .filter((e) => e.slug !== slug && !e.data.draft)
  .map((e) => ({
    entry: e,
    sharedTags: e.data.tags.filter((t) =>
      entry.data.tags.map((x) => x.toLowerCase()).includes(t.toLowerCase())
    ).length,
  }))
  .sort((a, b) => b.sharedTags - a.sharedTags || b.entry.data.publishDate.getTime() - a.entry.data.publishDate.getTime())
  .slice(0, 3)
  .map((r) => r.entry);

let Content = null;
if (entry.render && typeof entry.render === "function") {
  const rendered = await entry.render();
  Content = rendered.Content;
}

const mins = readingTime(entry.body);

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://redaction-technique.org";
const canonicalUrl = `${siteUrl}/blog/${slug}`;
const datePublished = entry.data.publishDate.toISOString().slice(0, 10);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: entry.data.title,
  description: entry.data.snippet,
  url: canonicalUrl,
  datePublished,
  dateModified: datePublished,
  image: entry.data.image?.src ? `${siteUrl}${entry.data.image.src}` : undefined,
  author: {
    "@type": "Person",
    name: entry.data.author ?? "Olivier Carrère",
    url: siteUrl,
  },
  publisher: {
    "@type": "Person",
    name: "Olivier Carrère",
    url: siteUrl,
  },
  keywords: entry.data.tags.join(", "),
};
---

<Layout
  title={entry.data.title}
  description={entry.data.snippet}
  ogImage={entry.data.image?.src}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div id="reading-progress" aria-hidden="true"></div>

  <div class="sticky top-14 z-40 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-5xl mx-auto px-4 h-9 flex items-center gap-1.5 text-sm text-gray-500 min-w-0">
      <a href="/" class="hover:text-gray-900 transition shrink-0">Home</a>
      <span class="text-gray-300 shrink-0">›</span>
      <a href="/" class="hover:text-gray-900 transition shrink-0">Blog</a>
      <span class="text-gray-300 shrink-0">›</span>
      <span class="text-gray-700 truncate">{entry.data.title}</span>
    </div>
  </div>

  <Container>
    <div class="mx-auto max-w-3xl mt-10">
      <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
        {entry.data.category}
      </span>
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {entry.data.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        {entry.data.author && <span class="text-gray-400">{entry.data.author}</span>}
        {entry.data.author && <span class="text-gray-400">•</span>}
        {entry.data.publishDate && (
          <time class="text-gray-400" datetime={entry.data.publishDate.toISOString()}>
            {entry.data.publishDate.toDateString()}
          </time>
        )}
        <span class="text-gray-400">•</span>
        <span class="text-gray-400">{mins} min read</span>
        <span class="text-gray-400 hidden md:block">•</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {entry.data.tags?.map((tag) => (
            <a
              href={`/tag/${tag.toLowerCase()}`}
              class="text-sm text-blue-500 hover:underline"
            >#{tag}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg mt-6 max-w-3xl">
      {Content ? <Content /> : <p>Content not available.</p>}
    </div>

    {relatedPosts.length > 0 && (
      <div class="mx-auto max-w-3xl mt-16 border-t pt-10">
        <h2 class="text-2xl font-bold mb-6">Related posts</h2>
        <div class="grid gap-6 sm:grid-cols-3">
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group block rounded-xl border border-gray-100 p-4 hover:border-blue-200 hover:bg-blue-50 transition"
            >
              {post.data.image?.src && (
                <img
                  src={post.data.image.src}
                  alt={post.data.image.alt ?? post.data.title}
                  class="w-full h-32 object-cover rounded-lg mb-3"
                  loading="lazy"
                />
              )}
              <p class="font-semibold text-sm leading-snug group-hover:text-blue-700 transition">
                {post.data.title}
              </p>
              <p class="text-xs text-gray-400 mt-1">
                {post.data.publishDate.toDateString()}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="text-center mt-10">
      <a
        href="/"
        class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition"
      >
        ← Back to Blog
      </a>
    </div>
  </Container>
</Layout>

<style>
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: #2563eb;
    transform-origin: left;
    transform: scaleX(0);
    z-index: 200;
    animation-name: grow-progress;
    animation-duration: auto;
    animation-timing-function: linear;
    animation-timeline: scroll();
  }

  @keyframes grow-progress {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
</style>
