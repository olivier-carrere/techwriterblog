---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

export const prerender = true;

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

function readingTime(body: string): number {
  const text = body
    .replace(/^import\s.+$/gm, "")
    .replace(/```[\s\S]*?```/g, "")
    .replace(/<[^>]+>/g, " ")
    .replace(/[#*`_~[\]()!>|]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  const words = text.split(" ").filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const { slug } = Astro.params;
const entries = await getCollection("blog");
const entry = entries.find((e) => e.slug === slug);

if (!entry) {
  throw new Error(`Blog entry not found for slug: ${slug}`);
}

// Related posts: rank by shared tags, exclude current, take top 3
const relatedPosts = entries
  .filter((e) => e.slug !== slug && !e.data.draft)
  .map((e) => ({
    entry: e,
    sharedTags: e.data.tags.filter((t) =>
      entry.data.tags.map((x) => x.toLowerCase()).includes(t.toLowerCase())
    ).length,
  }))
  .sort((a, b) => b.sharedTags - a.sharedTags || b.entry.data.publishDate.getTime() - a.entry.data.publishDate.getTime())
  .slice(0, 3)
  .map((r) => r.entry);

let Content = null;
if (entry.render && typeof entry.render === "function") {
  const rendered = await entry.render();
  Content = rendered.Content;
}

const mins = readingTime(entry.body);

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://redaction-technique.org";
const canonicalUrl = `${siteUrl}/blog/${slug}`;
const datePublished = entry.data.publishDate.toISOString().slice(0, 10);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: entry.data.title,
  description: entry.data.snippet,
  url: canonicalUrl,
  datePublished,
  dateModified: datePublished,
  image: entry.data.image?.src ? `${siteUrl}${entry.data.image.src}` : undefined,
  author: {
    "@type": "Person",
    name: entry.data.author ?? "Olivier Carrère",
    url: siteUrl,
  },
  publisher: {
    "@type": "Person",
    name: "Olivier Carrère",
    url: siteUrl,
  },
  keywords: entry.data.tags.join(", "),
};
---

<Layout
  title={entry.data.title}
  description={entry.data.snippet}
  ogImage={entry.data.image?.src}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div id="reading-progress" aria-hidden="true"></div>

  <div class="sticky top-14 z-40 bg-white dark:bg-slate-900 border-b border-gray-100 dark:border-slate-800 shadow-sm">
    <div class="max-w-5xl mx-auto px-4 h-9 flex items-center gap-1.5 text-sm text-gray-500 dark:text-slate-400 min-w-0">
      <a href="/" class="hover:text-gray-900 dark:hover:text-white transition shrink-0">Home</a>
      <span class="text-gray-300 dark:text-slate-600 shrink-0">›</span>
      <a href="/" class="hover:text-gray-900 dark:hover:text-white transition shrink-0">Blog</a>
      <span class="text-gray-300 dark:text-slate-600 shrink-0">›</span>
      <span class="text-gray-700 dark:text-slate-300 truncate">{entry.data.title}</span>
    </div>
  </div>

  <Container>
    <div class="mx-auto max-w-3xl mt-10">
      <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
        {entry.data.category}
      </span>
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {entry.data.title}
      </h1>
      <div class="mt-3 flex flex-col sm:flex-row sm:items-center sm:gap-2">
        <div class="flex items-center gap-2">
          {entry.data.author && <span class="text-gray-400">{entry.data.author}</span>}
          {entry.data.author && <span class="text-gray-400">•</span>}
          {entry.data.publishDate && (
            <time class="text-gray-400" datetime={entry.data.publishDate.toISOString()}>
              {entry.data.publishDate.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
            </time>
          )}
          <span class="text-gray-400">•</span>
          <span class="text-gray-400">{mins} min read</span>
        </div>
        <div class="flex flex-wrap gap-3 mt-1.5 sm:mt-0 sm:ml-1">
          <span class="text-gray-300 hidden sm:block">•</span>
          {entry.data.tags?.map((tag) => (
            <a
              href={`/tag/${tag.toLowerCase()}`}
              class="text-sm text-blue-500 hover:underline"
            >#{tag}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg dark:prose-invert mt-6" style="max-width: 68ch">
      {Content ? <Content /> : <p>Content not available.</p>}
    </div>

    {relatedPosts.length > 0 && (
      <div class="mx-auto max-w-3xl mt-16 border-t dark:border-slate-700 pt-10">
        <h2 class="text-2xl font-bold mb-6">Related posts</h2>
        <div class="grid gap-6 sm:grid-cols-3">
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group block rounded-xl border border-gray-100 dark:border-slate-700 p-4 hover:border-blue-200 dark:hover:border-blue-700 hover:bg-blue-50 dark:hover:bg-slate-800 transition"
            >
              {post.data.image?.src && (
                <img
                  src={post.data.image.src}
                  alt={post.data.image.alt ?? post.data.title}
                  class="w-full h-32 object-cover rounded-lg mb-3"
                  loading="lazy"
                />
              )}
              <p class="font-semibold text-sm leading-snug group-hover:text-blue-700 dark:text-slate-200 dark:group-hover:text-blue-400 transition">
                {post.data.title}
              </p>
              <p class="text-xs text-gray-400 dark:text-slate-500 mt-1">
                {post.data.publishDate.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- LinkedIn CTA -->
    <div class="mx-auto max-w-3xl mt-10 mb-16 rounded-xl bg-blue-50 dark:bg-slate-800 border border-blue-100 dark:border-slate-700 px-8 py-7 flex flex-col sm:flex-row items-center gap-5">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-10 h-10 fill-[#0A66C2] shrink-0" aria-hidden="true">
        <path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.88 0 54.11S24.09 0 53.79 0s53.79 24.22 53.79 54.11-24.1 54-53.79 54zM447.9 448h-92.68V302.4c0-34.7-12.42-58.3-43.5-58.3-23.73 0-37.84 16-44.04 31.4-2.28 5.6-2.85 13.4-2.85 21.2V448h-92.68s1.24-241.8 0-266.1h92.68v37.7c12.3-19 34.3-46.2 83.3-46.2 60.8 0 106.5 39.7 106.5 125.1V448z"/>
      </svg>
      <div class="flex-1 text-center sm:text-left">
        <p class="font-semibold text-gray-900 dark:text-white">Follow on LinkedIn for more</p>
        <p class="text-sm text-gray-500 dark:text-slate-300 mt-0.5">Articles on docs-as-code, DITA XML, YAML, and AI-assisted documentation.</p>
      </div>
      <a
        href="https://www.linkedin.com/in/carrereolivier/"
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 px-5 py-2.5 rounded-lg bg-[#0A66C2] text-white text-sm font-medium hover:bg-[#004182] transition"
      >
        Follow
      </a>
    </div>

    <div class="text-center mb-16">
      <a href="/" class="text-sm text-gray-400 hover:text-gray-700 transition">← Back to Blog</a>
    </div>
  </Container>
</Layout>

<script>
  const diagrams = document.querySelectorAll<HTMLElement>(".mermaid-diagram");
  if (diagrams.length > 0) {
    const { default: mermaid } = await import("mermaid");
    const isDark = document.documentElement.classList.contains("dark");
    mermaid.initialize({ startOnLoad: false, theme: isDark ? "dark" : "default" });
    for (const [i, el] of [...diagrams].entries()) {
      const chart = el.dataset.chart ?? "";
      try {
        const { svg } = await mermaid.render(`mermaid-${i}`, chart);
        el.innerHTML = svg;
      } catch {
        el.textContent = chart;
      }
    }
  }
</script>

<style>
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: #2563eb;
    transform-origin: left;
    transform: scaleX(0);
    z-index: 200;
    animation-name: grow-progress;
    animation-duration: auto;
    animation-timing-function: linear;
    animation-timeline: scroll();
  }

  @keyframes grow-progress {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
</style>
