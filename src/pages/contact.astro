---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Contact — Olivier Carrère, Technical Writer"
  description="Get in touch with Olivier Carrère, technical writer at Unity, to discuss documentation, docs-as-code, or AI-assisted workflows."
>
  <Container>
    <div class="mx-auto max-w-2xl mt-14 mb-20">

      <p class="text-blue-600 uppercase tracking-wider text-sm font-medium mb-3">Contact</p>
      <h1 class="text-4xl font-bold tracking-tight mb-4">Get in touch</h1>
      <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-10">
        I write about docs-as-code, DITA XML, structured authoring, and AI in documentation. If you
        want to discuss something you read, exchange ideas, or connect professionally — reach out via
        LinkedIn or email.
      </p>

      <div class="flex flex-col gap-4">
        <a
          href="https://www.linkedin.com/in/carrereolivier/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-5 py-3 rounded-lg border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:border-blue-400 hover:text-blue-700 dark:hover:text-blue-400 transition w-fit"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-4 h-4 fill-current shrink-0" aria-hidden="true">
            <path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.88 0 54.11S24.09 0 53.79 0s53.79 24.22 53.79 54.11-24.1 54-53.79 54zM447.9 448h-92.68V302.4c0-34.7-12.42-58.3-43.5-58.3-23.73 0-37.84 16-44.04 31.4-2.28 5.6-2.85 13.4-2.85 21.2V448h-92.68s1.24-241.8 0-266.1h92.68v37.7c12.3-19 34.3-46.2 83.3-46.2 60.8 0 106.5 39.7 106.5 125.1V448z"/>
          </svg>
          Connect on LinkedIn
        </a>

        <a
          href="mailto:olivier@redaction-technique.org"
          class="inline-flex items-center gap-3 px-5 py-3 rounded-lg border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:border-blue-400 hover:text-blue-700 dark:hover:text-blue-400 transition w-fit"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          olivier@redaction-technique.org
        </a>
      </div>

    </div>
  </Container>
</Layout>
