<aside
  aria-label="Get in touch"
  class="mx-auto mt-16 mb-4"
  style="max-width: 68ch"
>
  <div class="rounded-xl border border-gray-100 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/60 px-7 py-7 flex flex-col sm:flex-row sm:items-center gap-5">
    <div class="flex-1">
      <p class="font-semibold text-gray-900 dark:text-slate-100 mb-1">
        Want to discuss this article?
      </p>
      <p class="text-sm text-gray-500 dark:text-slate-400 leading-relaxed">
        Questions, feedback, or just want to exchange ideas on docs-as-code, DITA, or AI documentation — I read every message.
      </p>
    </div>
    <a
      href="/contact"
      class="shrink-0 px-5 py-2.5 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-slate-900 transition"
    >
      Get in touch
    </a>
  </div>
</aside>
