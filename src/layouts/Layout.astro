---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  author?: string;
  lang?: string;
  frAlternateUrl?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title, description, ogImage, ogType = "website", author, lang = 'en', frAlternateUrl } = Astro.props;

const makeTitle = title ? `${title} | Redaction-technique.org` : "A blog about all things documentation as code";
const metaDescription = description ?? "Expert articles on technical writing, docs-as-code, DITA XML, Markdown, YAML, and AI-assisted documentation workflows.";
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).toString() : resolvedImageWithDomain;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />
    {author && <meta name="author" content={author} />}
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    {frAlternateUrl && <link rel="alternate" hreflang="fr" href={frAlternateUrl} />}
    <SEO
      title={makeTitle}
      description={metaDescription}
      canonical={canonicalURL}
      twitter={{
        creator: "@OlivierCarrere",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: ogType,
          title: title ?? "Markdown & AI-Aided Rapid Documentation Development",
          image: ogImageUrl,
        },
        image: {
          alt: metaDescription,
        },
      }}
    />
    <Analytics />
    <slot name="head" />
    </head>
  <body class="bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 transition-colors duration-200">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
